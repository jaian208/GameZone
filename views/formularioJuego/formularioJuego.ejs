<!DOCTYPE html>
<html lang="es">

<%- include("../partials/head") %>

<body>

<%- include("../partials/navbar") %>

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-8"> <div class="card border-0 shadow-lg" style="background-color: #16202d;">

                <div class="card-header text-center border-secondary py-3" style="background-color: #1b2838;">
                    <h2 class="mb-0 fw-bold text-white">Añadir Juego al Arsenal</h2>
                </div>

                <div class="card-body p-4">

                    <form action="/formulario" method="POST">

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label for="nombre" class="form-label text-white-50">Título del Juego</label>
                                <input type="text" class="form-control bg-dark text-light border-secondary" id="nombre" name="nombre" required placeholder="Ej: Dead Space / Halo 3">
                            </div>

                            <div class="col-md-6 mb-3">
                                <label for="categoria" class="form-label text-white-50">Categoría / Consola</label>
                                <input type="text" class="form-control bg-dark text-light border-secondary" id="categoria" name="categoria" required placeholder="Ej: Survival Horror, Xbox, PC">
                            </div>
                        </div>

                        <div class="mb-3">
                            <label for="imagen_portada" class="form-label text-white-50">URL de la Portada</label>
                            <input type="url" class="form-control bg-dark text-light border-secondary" id="imagen_portada" name="imagen_portada" required placeholder="https://ejemplo.com/portada.jpg">
                        </div>

                        <div class="mb-3">
                            <label for="precio" class="form-label text-white-50">Precio (USD / COP)</label>
                            <input type="number" step="0.01" min="0" class="form-control bg-dark text-light border-secondary" id="precio" name="precio" required placeholder="Ej: 59.99">
                        </div>

                        <div class="mb-4">
                            <label for="descripcion" class="form-label text-white-50">Descripción / Sinopsis</label>
                            <textarea class="form-control bg-dark text-light border-secondary" id="descripcion" name="descripcion" rows="4" required placeholder="Ingresa los detalles épicos de la campaña..."></textarea>
                        </div>

                        <button type="submit" class="btn btn-primary w-100 btn-lg fw-bold">Desplegar en el Catálogo</button>
                    </form>
                </div>

                <div class="card-footer text-center border-secondary py-3" style="background-color: #1b2838;">
                    <p class="mb-0 text-white-50">Acceso restringido. Solo nivel de autorización <strong>Admin</strong>.</p>
                </div>

            </div>
        </div>
    </div>
</div>

<%- include("../partials/footer") %>

<script src="/js/home.js"></script>

</body>
</html>