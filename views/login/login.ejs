<!DOCTYPE html>
<html lang="es">

<%- include("../partials/head") %>

<body class="bg-dark text-light">

<%- include("../partials/navbar") %>

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-5">

            <div class="card border-0 shadow-lg" style="background-color: #16202d;">

                <div class="card-header text-center border-secondary py-3" style="background-color: #1b2838;">
                    <h2 class="mb-0 fw-bold">Iniciar Sesión</h2>
                </div>

                <div class="card-body p-4">

                    <form action="/login" method="POST">

                        <div class="mb-3">
                            <label for="email" class="form-label text-white-50">Correo de la UNSC</label>
                            <input type="email" class="form-control bg-dark text-light border-secondary" id="email" name="email" required placeholder="tu@correo.com">
                        </div>

                        <div class="mb-4">
                            <label for="password" class="form-label text-white-50">Contraseña</label>
                            <input type="password" class="form-control bg-dark text-light border-secondary" id="password" name="password" required>
                        </div>

                        <button type="submit" class="btn btn-primary w-100 btn-lg fw-bold">Acceder al Sistema</button>

                    </form>
                </div>

                <div class="card-footer text-center border-secondary py-3" style="background-color: #1b2838;">
                    <p class="mb-0">¿Aún no tienes autorización? <a href="/register" class="text-success text-decoration-none fw-bold">Regístrate aquí</a></p>
                </div>

            </div>
        </div>
    </div>
</div>

<%- include("../partials/footer") %>

<script src="/js/bootstrap.bundle.min.js"></script>

</body>
</html>